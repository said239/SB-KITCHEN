<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Said Boudhim - 3D Kitchen & Dressing Designer</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --gold-primary: #C8A951;
            --gold-light:   #D4B96A;
            --gold-dark:    #A68B3E;
            --dark-bg:      #1E1E1E;
            --darker-bg:    #141414;
            --card-bg:      #252525;
            --text-light:   #E8E8E8;
            --text-muted:   #A0A0A0;
        }
        body {
            font-family: 'Cairo', 'Tajawal', sans-serif;
            background: var(--dark-bg);
            color: var(--text-light);
            overflow-x: hidden;
        }

        /* ── ICON BASE ── */
        .icon {
            display: inline-block;
            width: 1em; height: 1em;
            fill: currentColor;
            vertical-align: -0.15em;
            flex-shrink: 0;
        }

        /* ── PARTICLES ── */
        #particles-canvas {
            position: fixed; top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none; z-index: 0;
        }

        /* ── HERO ── */
        .hero {
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, var(--dark-bg) 0%, var(--darker-bg) 50%, var(--dark-bg) 100%);
            position: relative; overflow: hidden;
        }
        .hero::before {
            content: ''; position: absolute;
            top: -50%; right: -20%;
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(200,169,81,0.1) 0%, transparent 70%);
            border-radius: 50%;
            animation: hero-glow 5s ease-in-out infinite;
        }
        .hero::after {
            content: ''; position: absolute;
            bottom: -30%; left: -10%;
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(200,169,81,0.05) 0%, transparent 70%);
            border-radius: 50%;
            animation: hero-glow 5s ease-in-out infinite 2.5s;
        }
        @keyframes hero-glow {
            0%,100% { transform: scale(1); opacity:.7; }
            50%      { transform: scale(1.3); opacity:1; }
        }
        .hero-container {
            display: flex; align-items: center; gap: 60px;
            max-width: 1200px; padding: 40px;
            position: relative; z-index: 1;
        }

        /* ── LOGO ── */
        .hero-logo {
            width: 180px; height: 180px;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            border-radius: 20px;
            display: flex; align-items: center; justify-content: center; flex-direction: column;
            box-shadow: 0 20px 60px rgba(200,169,81,0.35);
            position: relative; overflow: hidden; flex-shrink: 0;
            animation: logo-pop .9s cubic-bezier(0.34,1.56,0.64,1) .2s both;
            transition: transform .35s ease, box-shadow .35s ease;
        }
        @keyframes logo-pop {
            from { opacity:0; transform: scale(.4) rotate(-15deg); }
            to   { opacity:1; transform: scale(1) rotate(0deg); }
        }
        .hero-logo::before {
            content: ''; position: absolute;
            top:0; left:0; right:0; height:40%;
            background: rgba(255,255,255,0.12);
        }
        .hero-logo::after {
            content: ''; position: absolute;
            top:-60%; left:-80%; width:55%; height:220%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transform: skewX(-22deg);
            animation: logo-shimmer 3.5s ease-in-out infinite 1.5s;
        }
        @keyframes logo-shimmer { 0%{left:-80%} 100%{left:160%} }
        .hero-logo:hover {
            transform: scale(1.07) rotate(3deg);
            box-shadow: 0 30px 80px rgba(200,169,81,0.55);
        }
        .logo-icon {
            font-size: 48px; color: white; margin-bottom: 5px; z-index: 1;
            width: 1em; height: 1em;
            animation: wiggle 3s ease-in-out infinite 2s;
        }
        .logo-text { font-size: 42px; font-weight:800; color:white; letter-spacing:2px; z-index:1; }
        @keyframes wiggle {
            0%,100% { transform:rotate(0); }
            15%     { transform:rotate(-12deg); }
            30%     { transform:rotate(10deg); }
            45%     { transform:rotate(-8deg); }
            60%     { transform:rotate(6deg); }
            75%     { transform:rotate(0); }
        }

        /* ── HERO CONTENT ── */
        .hero-content { flex:1; }
        .hero-title {
            font-size:3.5rem; font-weight:700; margin-bottom:10px; color:white;
            animation: slide-right .8s ease .5s both;
        }
        @keyframes slide-right {
            from { opacity:0; transform:translateX(50px); }
            to   { opacity:1; transform:translateX(0); }
        }
        .hero-subtitle {
            font-size:1.3rem; color:var(--gold-primary); font-weight:600;
            margin-bottom:30px; letter-spacing:1px; min-height:2rem;
            animation: slide-right .8s ease .7s both;
        }
        .hero-subtitle.done::after {
            content:'|'; animation: blink .9s step-end infinite;
        }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
        .hero-description {
            font-size:1.1rem; line-height:2.1; color:var(--text-muted); margin-bottom:30px;
            animation: slide-right .8s ease .9s both;
        }
        .hero-description p { transition: color .3s; display: flex; align-items: center; }
        .hero-description p:hover { color: var(--text-light); }
        .hero-description .icon { color:var(--gold-primary); margin-left:8px; font-size:1.2em; }
        .hero-description p:nth-child(1) .icon { animation: icon-bounce 2.5s ease-in-out infinite 1.2s; }
        .hero-description p:nth-child(2) .icon { animation: icon-bounce 2.5s ease-in-out infinite 1.6s; }
        .hero-description p:nth-child(3) .icon { animation: icon-bounce 2.5s ease-in-out infinite 2.0s; }
        @keyframes icon-bounce {
            0%,100% { transform:translateY(0); }
            30%     { transform:translateY(-5px); }
            50%     { transform:translateY(0); }
            70%     { transform:translateY(-3px); }
        }
        .contact-info { display:flex; gap:25px; flex-wrap:wrap; animation: slide-right .8s ease 1.1s both; }
        .contact-item {
            display:flex; align-items:center; gap:10px;
            color:var(--text-light); text-decoration:none; font-size:1.1rem;
            transition: all .3s ease; padding:8px 16px; border-radius:10px;
            background:rgba(200,169,81,0.1); border:1px solid rgba(200,169,81,0.1);
            position:relative; overflow:hidden;
        }
        .contact-item::after {
            content:''; position:absolute; top:0; left:-100%;
            width:100%; height:100%;
            background:linear-gradient(90deg,transparent,rgba(200,169,81,0.15),transparent);
            transition: left .45s ease;
        }
        .contact-item:hover::after { left:100%; }
        .contact-item:hover {
            background:rgba(200,169,81,0.2); color:var(--gold-primary);
            transform:translateY(-4px); border-color:rgba(200,169,81,0.35);
            box-shadow:0 10px 28px rgba(200,169,81,0.2);
        }
        .contact-item .icon { color:var(--gold-primary); font-size:1.2rem; width:1.2rem; height:1.2rem; }
        .contact-item:hover .icon { animation: spin-once .5s ease forwards; }
        @keyframes spin-once {
            from { transform:rotate(0) scale(1); }
            50%  { transform:rotate(180deg) scale(1.3); }
            to   { transform:rotate(360deg) scale(1); }
        }

        /* ── SERVICES ── */
        .services-section { padding:80px 20px; background:var(--darker-bg); position:relative; }
        .services-section::before {
            content:''; position:absolute; top:0; left:50%; transform:translateX(-50%);
            width:0; height:3px;
            background:linear-gradient(90deg,transparent,var(--gold-primary),transparent);
            transition: width 1s ease;
        }
        .services-section.sec-visible::before { width:120px; }
        .section-title, .section-subtitle {
            opacity:0; transform:translateY(25px);
            transition: opacity .7s ease, transform .7s ease;
        }
        .section-title.visible  { opacity:1; transform:translateY(0); }
        .section-subtitle.visible { opacity:1; transform:translateY(0); transition-delay:.15s; }
        .section-title { text-align:center; font-size:2.5rem; font-weight:700; margin-bottom:15px; color:white; }
        .section-subtitle { text-align:center; font-size:1.1rem; color:var(--gold-primary); margin-bottom:50px; }

        /* ── CARDS ── */
        .cards-wrapper { max-width:1200px; margin:0 auto; position:relative; }
        .cards-container {
            display:flex; gap:30px; overflow-x:auto;
            scroll-behavior:smooth; scroll-snap-type:x mandatory;
            padding:20px 10px 40px; -webkit-overflow-scrolling:touch; scrollbar-width:none;
        }
        .cards-container::-webkit-scrollbar { display:none; }
        .service-card {
            min-width:320px; max-width:320px;
            background:linear-gradient(145deg,var(--card-bg),#2a2a2a);
            border-radius:20px; padding:35px 30px; scroll-snap-align:center;
            border:1px solid rgba(200,169,81,0.15);
            transition: transform .45s cubic-bezier(.25,.46,.45,.94), border-color .45s, box-shadow .45s, opacity .6s;
            position:relative; overflow:hidden; opacity:0; transform:translateY(45px) scale(.95);
        }
        .service-card.visible { opacity:1; transform:translateY(0) scale(1); }
        .service-card::before {
            content:''; position:absolute; top:0; left:0; right:0; height:4px;
            background:linear-gradient(90deg,var(--gold-primary),var(--gold-light));
            transform:scaleX(0.6); transform-origin:right; transition:transform .4s ease;
        }
        .service-card:hover::before { transform:scaleX(1); }
        .service-card::after {
            content:''; position:absolute; top:-60%; left:-80%;
            width:55%; height:220%;
            background:linear-gradient(90deg,transparent,rgba(255,255,255,0.04),transparent);
            transform:skewX(-22deg); transition:left .65s ease;
        }
        .service-card:hover::after { left:160%; }
        .service-card:hover {
            transform:translateY(-13px) scale(1.02);
            border-color:rgba(200,169,81,0.5);
            box-shadow:0 28px 55px rgba(0,0,0,0.5), 0 0 40px rgba(200,169,81,0.13);
        }
        .card-icon {
            width:70px; height:70px;
            background:linear-gradient(135deg,rgba(200,169,81,0.2),rgba(200,169,81,0.05));
            border-radius:16px; display:flex; align-items:center; justify-content:center;
            margin-bottom:25px; font-size:28px; color:var(--gold-primary);
            border:1px solid rgba(200,169,81,0.2);
            transition: transform .35s ease, box-shadow .35s ease, background .35s ease;
        }
        .card-icon .icon { width:28px; height:28px; }
        .service-card:hover .card-icon {
            transform:scale(1.12) rotate(6deg);
            background:linear-gradient(135deg,rgba(200,169,81,0.32),rgba(200,169,81,0.12));
            box-shadow:0 8px 25px rgba(200,169,81,0.22);
        }
        .service-card.visible .card-icon .icon { animation: icon-float 3s ease-in-out infinite; }
        .service-card:nth-child(1) .card-icon .icon { animation-delay:.0s; }
        .service-card:nth-child(2) .card-icon .icon { animation-delay:.4s; }
        .service-card:nth-child(3) .card-icon .icon { animation-delay:.8s; }
        .service-card:nth-child(4) .card-icon .icon { animation-delay:1.2s; }
        .service-card:nth-child(5) .card-icon .icon { animation-delay:1.6s; }
        .service-card:nth-child(6) .card-icon .icon { animation-delay:2.0s; }
        @keyframes icon-float {
            0%,100% { transform:translateY(0) scale(1); }
            50%     { transform:translateY(-5px) scale(1.05); }
        }
        .service-card:hover .card-icon .icon { animation:icon-spin .6s ease forwards !important; }
        @keyframes icon-spin {
            from { transform:rotate(0) scale(1); }
            to   { transform:rotate(360deg) scale(1.1); }
        }
        .card-title { font-size:1.3rem; font-weight:700; margin-bottom:15px; color:white; }
        .card-description { font-size:.95rem; line-height:1.8; color:var(--text-muted); }
        .card-badge {
            display:inline-block; margin-top:15px; padding:6px 14px;
            background:rgba(200,169,81,0.15); color:var(--gold-primary);
            border-radius:20px; font-size:.8rem; font-weight:600;
            border:1px solid rgba(200,169,81,0.2); transition:background .3s, border-color .3s;
        }
        .service-card:hover .card-badge { background:rgba(200,169,81,0.27); border-color:rgba(200,169,81,0.45); }

        /* ── NAV ── */
        .nav-arrows { display:flex; justify-content:center; gap:20px; margin-top:30px; }
        .nav-btn {
            width:50px; height:50px; border-radius:50%;
            border:2px solid var(--gold-primary); background:transparent;
            color:var(--gold-primary); cursor:pointer;
            transition: all .3s ease; display:flex; align-items:center; justify-content:center;
        }
        .nav-btn .icon { width:1.2rem; height:1.2rem; animation: arrow-pulse 2s ease-in-out infinite; }
        .nav-btn:first-child .icon { animation-delay:0s; }
        .nav-btn:last-child  .icon { animation-delay:1s; }
        @keyframes arrow-pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.35)} }
        .nav-btn:hover { background:var(--gold-primary); color:var(--dark-bg); transform:scale(1.15); box-shadow:0 0 22px rgba(200,169,81,0.45); }
        .nav-btn:hover .icon { animation:none; transform:scale(1.2); }
        .nav-btn:active { transform:scale(.93); }

        .swipe-hint {
            text-align:center; margin-top:15px; color:var(--text-muted); font-size:.9rem;
            display:flex; align-items:center; justify-content:center; gap:8px;
        }
        .swipe-hint .icon { color:var(--gold-primary); width:.9rem; height:.9rem; animation: finger-wave 1.8s ease-in-out infinite; }
        @keyframes finger-wave {
            0%,100% { transform:translateX(0) rotate(0); }
            25%     { transform:translateX(-8px) rotate(-10deg); }
            75%     { transform:translateX(4px) rotate(5deg); }
        }

        /* ── COVERAGE ── */
        .coverage-section { padding:80px 20px; background:var(--dark-bg); text-align:center; }
        .coverage-map {
            max-width:800px; margin:40px auto; padding:40px;
            background:linear-gradient(145deg,var(--card-bg),#2a2a2a);
            border-radius:20px; border:1px solid rgba(200,169,81,0.15);
            opacity:0; transform:scale(.93);
            transition: opacity .8s ease, transform .8s ease, border-color .4s, box-shadow .4s;
        }
        .coverage-map.visible { opacity:1; transform:scale(1); }
        .coverage-map:hover { border-color:rgba(200,169,81,0.35); box-shadow:0 20px 55px rgba(0,0,0,0.4),0 0 35px rgba(200,169,81,0.1); }
        .map-icon {
            font-size:60px; color:var(--gold-primary); margin-bottom:20px; display:block;
            width:60px; height:60px; margin:0 auto 20px;
            animation: float 3.5s ease-in-out infinite;
        }
        @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
        .coverage-text { font-size:1.3rem; font-weight:600; color:white; margin-bottom:10px; }
        .coverage-detail { font-size:1rem; color:var(--text-muted); }
        .coverage-detail span { color:var(--gold-primary); font-weight:700; }

        /* ── FOOTER ── */
        .footer {
            padding:40px 20px; background:var(--darker-bg);
            text-align:center; border-top:1px solid rgba(200,169,81,0.1);
        }
        .footer-logo { font-size:2rem; font-weight:800; color:var(--gold-primary); margin-bottom:15px; animation: glow-pulse 2.5s ease-in-out infinite; }
        @keyframes glow-pulse {
            0%,100% { text-shadow:0 0 12px rgba(200,169,81,0.3); }
            50%     { text-shadow:0 0 30px rgba(200,169,81,0.8),0 0 60px rgba(200,169,81,0.3); }
        }
        .footer-text { color:var(--text-muted); font-size:.9rem; }

        /* ── RESPONSIVE ── */
        @media(max-width:768px) {
            .hero-container { flex-direction:column; text-align:center; gap:30px; }
            .hero-title     { font-size:2.2rem; }
            .hero-subtitle  { font-size:1rem; }
            .hero-logo      { width:140px; height:140px; }
            .logo-text      { font-size:32px; }
            .contact-info   { justify-content:center; }
            .service-card   { min-width:280px; max-width:280px; }
            .section-title  { font-size:1.8rem; }
        }
    </style>
</head>
<body>

<svg style="display:none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <symbol id="i-utensils" viewBox="0 0 24 24">
      <path d="M11 2v5.5A1.5 1.5 0 0 1 9.5 9H9v13H7V9h-.5A1.5 1.5 0 0 1 5 7.5V2H6v5h1V2h1v5h1V2h1zM17 2c-1.1 0-3 .9-3 4v3h2v13h2V2h-1z"/>
    </symbol>
    <symbol id="i-home" viewBox="0 0 24 24">
      <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
    </symbol>
    <symbol id="i-laptop" viewBox="0 0 24 24">
      <path d="M20 18c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2H0v2h24v-2h-4zM4 6h16v10H4V6z"/>
    </symbol>
    <symbol id="i-star" viewBox="0 0 24 24">
      <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
    </symbol>
    <symbol id="i-phone" viewBox="0 0 24 24">
      <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/>
    </symbol>
    <symbol id="i-instagram" viewBox="0 0 24 24">
      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
    </symbol>
    <symbol id="i-palette" viewBox="0 0 24 24">
      <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9c.83 0 1.5-.67 1.5-1.5 0-.39-.15-.74-.39-1.01-.23-.26-.38-.61-.38-.99 0-.83.67-1.5 1.5-1.5H16c2.76 0 5-2.24 5-5 0-4.42-4.03-8-9-8zm-5.5 9c-.83 0-1.5-.67-1.5-1.5S5.67 9 6.5 9 8 9.67 8 10.5 7.33 12 6.5 12zm3-4C8.67 8 8 7.33 8 6.5S8.67 5 9.5 5s1.5.67 1.5 1.5S10.33 8 9.5 8zm5 0c-.83 0-1.5-.67-1.5-1.5S13.67 5 14.5 5s1.5.67 1.5 1.5S15.33 8 14.5 8zm3 4c-.83 0-1.5-.67-1.5-1.5S16.67 9 17.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
    </symbol>
    <symbol id="i-map" viewBox="0 0 24 24">
      <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
    </symbol>
    <symbol id="i-chevron-right" viewBox="0 0 24 24">
      <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
    </symbol>
    <symbol id="i-chevron-left" viewBox="0 0 24 24">
      <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
    </symbol>
    <symbol id="i-hand" viewBox="0 0 24 24">
      <path d="M9 11.24V7.5C9 6.12 10.12 5 11.5 5S14 6.12 14 7.5v3.74c1.21-.81 2-2.18 2-3.74C16 5.01 13.99 3 11.5 3S7 5.01 7 7.5c0 1.56.79 2.93 2 3.74zm9.84 4.63l-4.54-2.26c-.17-.07-.35-.11-.54-.11H13v-6c0-.83-.67-1.5-1.5-1.5S10 6.67 10 7.5v10.74l-3.43-.72c-.08-.01-.15-.03-.24-.03-.31 0-.59.13-.79.33l-.79.8 4.94 4.94c.27.27.65.44 1.06.44h6.79c.75 0 1.33-.55 1.44-1.28l.75-5.27c.01-.07.02-.14.02-.2 0-.62-.35-1.17-.89-1.38z"/>
    </symbol>
  </defs>
</svg>

<canvas id="particles-canvas"></canvas>

<header class="hero">
    <div class="hero-container">
        <div class="hero-logo">
            <svg class="logo-icon"><use href="#i-home"></use></svg>
            <span class="logo-text">SB</span>
        </div>
        <div class="hero-content">
            <h1 class="hero-title">Said Boudhim</h1>
            <div class="hero-subtitle done">3D Kitchen & Dressing Designer</div>
            <div class="hero-description">
                <p>تصميم مطابخ عصرية <svg class="icon"><use href="#i-utensils"></use></svg></p>
                <p>تصميم دريسينج روم وغرف النوم <svg class="icon"><use href="#i-home"></use></svg></p>
                <p>تصاميم ثلاثية الأبعاد واقعية 3D <svg class="icon"><use href="#i-laptop"></use></svg></p>
            </div>
            <div class="contact-info">
                <a href="tel:+212000000000" class="contact-item">
                    <svg class="icon"><use href="#i-phone"></use></svg>
                    اتصل بنا
                </a>
                <a href="#" class="contact-item">
