    </div>
</header>

<section class="services-section">
    <h2 class="section-title">خدماتنا</h2>
    <p class="section-subtitle">أفضل التصاميم بأحدث البرامج وتقنيات 3D</p>
    
    <div class="cards-wrapper">
        <div class="cards-container">
            <div class="service-card">
                <div class="card-icon"><svg class="icon"><use href="#i-utensils"></use></svg></div>
                <h3 class="card-title">مطابخ عصرية</h3>
                <p class="card-description">تصميم مطابخ حديثة تستغل المساحات بشكل ذكي وتوفر لك الراحة والجمالية في نفس الوقت.</p>
                <span class="card-badge">Kitchen Design</span>
            </div>
            
            <div class="service-card">
                <div class="card-icon"><svg class="icon"><use href="#i-home"></use></svg></div>
                <h3 class="card-title">دريسينج روم</h3>
                <p class="card-description">خزائن ملابس مخصصة تناسب احتياجاتك وتضفي لمسة من الفخامة على غرفتك.</p>
                <span class="card-badge">Dressing Room</span>
            </div>

            <div class="service-card">
                <div class="card-icon"><svg class="icon"><use href="#i-laptop"></use></svg></div>
                <h3 class="card-title">تصميم 3D واقعي</h3>
                <p class="card-description">شاهد مطبخك أو غرفتك قبل التنفيذ من خلال تصاميم ثلاثية الأبعاد عالية الدقة.</p>
                <span class="card-badge">3D Rendering</span>
            </div>

            <div class="service-card">
                <div class="card-icon"><svg class="icon"><use href="#i-palette"></use></svg></div>
                <h3 class="card-title">تناسق الألوان</h3>
                <p class="card-description">مساعدتك في اختيار أفضل الألوان والمواد التي تناسب ذوقك وتصميم منزلك.</p>
                <span class="card-badge">Color Palette</span>
            </div>
            
             <div class="service-card">
                <div class="card-icon"><svg class="icon"><use href="#i-star"></use></svg></div>
                <h3 class="card-title">استشارات التصميم</h3>
                <p class="card-description">نقدم لك النصائح والأفكار المبتكرة لاستغلال كل زاوية في منزلك.</p>
                <span class="card-badge">Consultation</span>
            </div>
        </div>
        
        <div class="nav-arrows">
            <button class="nav-btn" id="btn-right"><svg class="icon"><use href="#i-chevron-right"></use></svg></button>
            <button class="nav-btn" id="btn-left"><svg class="icon"><use href="#i-chevron-left"></use></svg></button>
        </div>
        
        <div class="swipe-hint">
            <svg class="icon"><use href="#i-hand"></use></svg>
            اسحب لليمين أو اليسار للمزيد
        </div>
    </div>
</section>

<section class="coverage-section">
    <div class="coverage-map">
        <svg class="map-icon"><use href="#i-map"></use></svg>
        <h3 class="coverage-text">نغطي جميع أنحاء المغرب</h3>
        <p class="coverage-detail">سواء كنت في <span>آسفي</span>، <span>الدار البيضاء</span>، <span>الرباط</span> أو أي مدينة أخرى، نحن هنا لخدمتك.</p>
    </div>
</section>

<footer class="footer">
    <div class="footer-logo">SB DESIGN</div>
    <p class="footer-text">© 2026 Said Boudhim - 3D Kitchen & Dressing Designer. All rights reserved.</p>
</footer>

<script>
    // 1. Particles Background Effect
    const canvas = document.getElementById('particles-canvas');
    const ctx = canvas.getContext('2d');
    
    function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    const particles = [];
    for(let i=0; i<60; i++) {
        particles.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.5,
            vy: (Math.random() - 0.5) * 0.5,
            size: Math.random() * 2.5
        });
    }

    function animateParticles() {
        requestAnimationFrame(animateParticles);
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = 'rgba(200, 169, 81, 0.4)';
        
        particles.forEach(p => {
            p.x += p.vx;
            p.y += p.vy;
            
            if(p.x < 0 || p.x > canvas.width) p.vx *= -1;
            if(p.y < 0 || p.y > canvas.height) p.vy *= -1;
            
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
            ctx.fill();
        });
    }
    animateParticles();

    // 2. Scroll Animation Observer (لإظهار العناصر بسلاسة)
    const observerOptions = {
        threshold: 0.1,
        rootMargin: "0px 0px -50px 0px"
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
                // Add delay for cards to appear one by one
                if(entry.target.classList.contains('service-card')) {
                    setTimeout(() => {
                        entry.target.classList.add('visible');
                    }, index * 100);
                } else {
                    entry.target.classList.add('visible', 'sec-visible');
                }
                observer.unobserve(entry.target);
            }
        });
    }, observerOptions);

    document.querySelectorAll('.section-title, .section-subtitle, .service-card, .coverage-map, .services-section').forEach(el => {
        observer.observe(el);
    });

    // 3. Slider Navigation
    const cardsContainer = document.querySelector('.cards-container');
    const btnRight = document.getElementById('btn-right');
    const btnLeft = document.getElementById('btn-left');

    // للغة العربية (RTL) اتجاه السحب كيكون معكوس
    btnRight.addEventListener('click', () => {
        cardsContainer.scrollBy({ left: 350, behavior: 'smooth' });
    });

    btnLeft.addEventListener('click', () => {
        cardsContainer.scrollBy({ left: -350, behavior: 'smooth' });
    });
</script>

</body>
</html>
